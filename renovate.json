{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "after day 5 and before day 28"
  ],
  "timezone": "UTC",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Dockerfile ARG pins preceded by # renovate: (datasource + depName + optional versioning)",
      "managerFilePatterns": [
        "/(^|/|\\.)([Dd]ocker|[Cc]ontainer)file$/",
        "/(^|/)([Dd]ocker|[Cc]ontainer)file[^/]*$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: registryUrl=(?<registryUrl>\\S+))?(?: versioning=(?<versioning>\\S+))?\\s*(?:\\r\\n|\\n|\\r)ARG [A-Z0-9_]+=(?<currentValue>[^\\r\\n]+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "PyPI versions in Dockerfiles follow PEP 440 (comments omit explicit versioning=)",
      "matchDatasources": [
        "pypi"
      ],
      "matchManagers": [
        "custom.regex"
      ],
      "versioning": "pep440"
    },
    {
      "description": "deb datasource in Dockerfiles (e.g. CARTA via PPA) uses native deb versioning: epoch colons, ~prerelease suffixes, -N revisions",
      "matchDatasources": [
        "deb"
      ],
      "matchManagers": [
        "custom.regex"
      ],
      "versioning": "deb"
    }
  ]
}
